# Copy to .env and adjust values for your runtime.
# Compose usage examples:
#   Podman: podman compose --env-file .env -f compose.sign-setup.yml up -d --force-recreate
#   Docker: docker compose --env-file .env -f compose.sign-setup.yml up -d --force-recreate

# Host container runtime socket source mounted to /var/run/docker.sock in the container.
# Docker default:
# CONTAINER_HOST_SOCKET=/var/run/docker.sock
# Podman on this setup:
CONTAINER_HOST_SOCKET=/run/podman/podman.sock

# Container timezone
TZ=UTC

# initialize.sh signing defaults
EMAIL=your-email@example.com
KEY_NAME=n5-key
OUTPUT_DIR=/data

# Set to 1 for the intended one-time secrets bootstrap (requires store auth).
# Set to 0 to allow local key generation without store login.
REQUIRE_SNAPCRAFT_AUTH=1

# Optional Snap Store credentials for headless/container auth.
# Leave empty to skip snapcraft store-auth-required operations.
SNAPCRAFT_STORE_CREDENTIALS=
